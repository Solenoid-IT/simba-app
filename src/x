        function cert_get_expire_time (string $file_path) : int
        {
            // (Getting the value)
            $output = shell_exec( "openssl x509 -in $file_path -noout -enddate" );



            // Returning the value
            return strtotime( str_replace( 'notAfter=', '', $output ) );
        }



        if ( !isset( $argv[2] ) )
