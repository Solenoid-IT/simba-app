                    // Printing the value
                    echo "\n\nCertificate will expire at '" . date( 'c', $expire_time ) . "' :: Still valid, no need to generate a new one !\n\n\n";



                    // Returning the value
                    return;
                }
            }
        }



        // (Executing the commands)
        system( 'mkdir ' . __DIR__ . '/storage/cert' );
        system( 'rm -rf ' . __DIR__ . '/storage/cert/*' );
        system( "openssl req -x509 -newkey rsa:$bit_depth -nodes -keyout $key_file_path -out $crt_file_path -days $duration_days -subj \"/C=IT/ST=Piedmont/L=Turin/O=Simba/CN=simba.dev\"" );
        system( 'chown -R www-data:www-data storage/cert' );
