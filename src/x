// Returns [assoc]
function get_envs ()
{
    // (Including the file)
    include_once( __DIR__ . '/autoload.php' );



    // (Getting the value)
    $env = new \Solenoid\X\Env( __DIR__ . '/.env' );



    // (Getting the value)
    $envs =
    [
        'APP_NAME' => $env->get( 'APP_NAME' )
    ]
    ;



    // Returning the value
    return $envs;
}



function get_cli_user ()
{
    // (Getting the value)
    $real_user = getenv( 'SUDO_USER' );

    if ( $real_user )
    {// Value found
        // (Getting the value)
        $cli_user = $real_user;
    }
    else
    {// Value not found
        // (Getting the value)
        $cli_user = posix_getpwuid( posix_getuid() )['name'];
    }



    // Returning the value
    return $cli_user;
}



function set_perms (string $cli_user, string $http_user)
{
    // (Getting the value)
    $logs_basedir = __DIR__ . '/storage/logs/app';



    // (Executing the commands)
    system( "mkdir -p $logs_basedir" );
    system( "mkdir $logs_basedir/cli" );
    system( "mkdir $logs_basedir/http" );
    system( "chown -R $cli_user:$http_user $logs_basedir" );
    system( "find $logs_basedir -type d -exec chmod 775 {} +" );
    system( "find $logs_basedir -type f -exec chmod 664 {} +" );
}



